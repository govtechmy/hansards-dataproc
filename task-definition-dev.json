{
  "containerDefinitions": [
    {
      "image": "602670427499.dkr.ecr.ap-southeast-5.amazonaws.com/hsd-mod-dataproc-dev:latest",
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hsd-mod-dataproc-dev",
          "awslogs-region": "ap-southeast-5",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "mountPoints": [],
      "name": "hsd-mod-dataproc",
      "portMappings": [
        { "containerPort": 3000, "hostPort": 3000, "name": "hsd-mod-dataproc", "protocol": "tcp" }
      ],
      "stopTimeout": 2,
      "secrets": [
        {
          "name": "DAGSTER_DB_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-5:602670427499:secret:hsd-mod-dataproc-secret-dev"
        }
      ]
    }
  ],
  "cpu": "1024",
  "executionRoleArn": "arn:aws:iam::602670427499:role/hsd-ecsTaskExecutionRole-dev",
  "family": "hsd-mod-dataproc-dev",
  "memory": "2048",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "taskRoleArn": "arn:aws:iam::602670427499:role/hsd-ecs-task-role-dev"
}
