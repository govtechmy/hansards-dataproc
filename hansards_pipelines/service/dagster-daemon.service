[Unit]
Description=Dagster Daemon
After=network.target
Requires=dagster-webserver.service

[Service]
Type=simple
User=ec2-user
Environment=DAGSTER_HOME=/opt/dagster/dagster_home
Environment=PATH=/home/ec2-user/hansards-dataproc/env/bin:/usr/bin:$PATH
Environment=VIRTUAL_ENV=/home/ec2-user/hansards-dataproc/env
WorkingDirectory=/home/ec2-user/hansards-dataproc/hansards_pipelines
ExecStart=/home/ec2-user/hansards-dataproc/env/bin/dagster-daemon run
Restart=always
RestartSec=10
StartLimitInterval=0

[Install]
WantedBy=multi-user.target